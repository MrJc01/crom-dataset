        // Helper to get type info
        function getTypeInfo(typeId) {
            for (const category in fileTypes) {
                const found = fileTypes[category].find(t => t.id === typeId);
                if (found) return found;
            }
            return { name: 'Arquivo', icon: 'ph-file', color: 'text-gray-500', bg: 'bg-gray-100' };
        }

        function renderFilters(profile) {
            const container = document.getElementById('file-type-filters');
            container.innerHTML = '';
            
            let typesToRender = [];
            if (profile === 'all') {
                typesToRender = [...fileTypes.video, ...fileTypes.dev, ...fileTypes.design];
            } else {
                typesToRender = fileTypes[profile];
            }

            typesToRender.forEach(type => {
                const html = `
                    <label class="flex items-center gap-3 group cursor-pointer">
                        <input type="checkbox" checked class="h-4 w-4 text-brand-600 focus:ring-brand-500 border-gray-300 rounded">
                        <div class="flex items-center gap-2 text-sm text-gray-700 group-hover:text-gray-900">
                            <span class="flex items-center justify-center w-6 h-6 rounded ${type.bg} ${type.color}">
                                <i class="ph ${type.icon}"></i>
                            </span>
                            ${type.name}
                        </div>
                    </label>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        function renderGrid(profile) {
            const container = document.getElementById('results-grid');
            container.innerHTML = '';
            
            let dataToRender = mockData;
            if (profile !== 'all') {
                dataToRender = mockData.filter(item => item.profile === profile);
            }

            document.getElementById('results-count').innerText = `Mostrando ${dataToRender.length} resultados`;

            dataToRender.forEach((item, index) => {
                const typeInfo = getTypeInfo(item.type);
                const delay = index * 50; // Staggered animation
                
                // Content representation (Image vs Code block)
                let previewHtml = '';
                if (item.isCode) {
                    previewHtml = `
                        <div class="absolute inset-0 bg-slate-800 p-4 font-mono text-xs overflow-hidden flex flex-col">
                            <div class="flex gap-1.5 mb-3">
                                <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
                            </div>
                            <div class="text-green-400 opacity-80 flex-1 overflow-hidden">
                                // ${item.title}<br>
                                data = load('${item.type}')<br>
                                <span class="text-blue-300">function</span> process(data) {<br>
                                &nbsp;&nbsp;<span class="text-pink-300">return</span> data.map(i => i.val);<br>
                                }<br>
                                ...
                            </div>
                        </div>
                    `;
                } else if (item.image) {
                    previewHtml = `<img src="${item.image}" alt="${item.title}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">`;
                } else {
                    previewHtml = `
                        <div class="absolute inset-0 bg-gray-100 flex items-center justify-center group-hover:bg-gray-200 transition-colors">
                            <i class="ph ${typeInfo.icon} text-6xl text-gray-300"></i>
                        </div>
                    `;
                }

                const html = `
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col group fade-in cursor-pointer" style="animation-delay: ${delay}ms; animation-fill-mode: both;" onclick="openModal(${item.id})">
                        <!-- Card Header / Preview -->
                        <div class="h-40 w-full relative bg-gray-100 overflow-hidden border-b border-gray-100">
                            ${previewHtml}
                            
                            <!-- Overlay actions -->
                            <div class="absolute inset-0 bg-gray-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3 backdrop-blur-[2px]">
                                <button class="bg-white text-gray-900 rounded-full p-2.5 shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-all hover:bg-brand-50 hover:text-brand-600" title="Visualizar">
                                    <i class="ph ph-eye text-lg"></i>
                                </button>
                                <button class="bg-brand-600 text-white rounded-full p-2.5 shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-all delay-75 hover:bg-brand-500" title="Baixar Rápido">
                                    <i class="ph ph-download-simple text-lg"></i>
                                </button>
                            </div>
                            
                            <!-- Badges -->
                            <div class="absolute top-2 left-2 flex gap-2">
                                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md text-xs font-medium bg-white/90 shadow-sm text-gray-700 backdrop-blur-sm">
                                    <span class="w-2 h-2 rounded-full ${typeInfo.color.replace('text-', 'bg-')}"></span>
                                    .${item.type}
                                </span>
                            </div>
                        </div>
                        
                        <!-- Card Body -->
                        <div class="p-4 flex-1 flex flex-col">
                            <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 leading-tight mb-1 group-hover:text-brand-600 transition-colors">${item.title}</h3>
                            <p class="text-xs text-gray-500 line-clamp-2 flex-1 mt-1">${item.desc}</p>
                            
                            <!-- Meta Footer -->
                            <div class="mt-4 flex items-center justify-between text-xs text-gray-500 border-t border-gray-100 pt-3">
                                <div class="flex items-center gap-1.5">
                                    <i class="ph ph-hard-drives text-gray-400"></i>
                                    ${item.size}
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <i class="ph ph-download-simple text-gray-400"></i>
                                    ${item.downloads}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        function setProfile(profile) {
            // Update buttons styling
            const buttons = document.querySelectorAll('aside button');
            buttons.forEach(btn => {
                btn.className = "w-full flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors group";
                btn.querySelector('i').className = btn.querySelector('i').className.replace('text-brand-500', 'text-gray-400');
            });

            // Set active button
            let activeBtn;
            if (profile === 'all') activeBtn = document.getElementById('btn-profile-all');
            else activeBtn = document.querySelector(`aside button[onclick="setProfile('${profile}')"]`);
            
            if(activeBtn) {
                activeBtn.className = "w-full flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg bg-brand-50 text-brand-700 transition-colors shadow-sm ring-1 ring-brand-100";
                activeBtn.querySelector('i').className = activeBtn.querySelector('i').className.replace('text-gray-400', 'text-brand-600').replace('text-gray-500', 'text-brand-600');
            }

            // Update Label
            const labels = {
                'video': 'Editor de Vídeo',
                'dev': 'Programador / Data',
                'design': 'Designer',
                'all': 'Todos'
            };
            document.getElementById('active-profile-label').innerText = labels[profile];

            // Re-render
            renderFilters(profile);
            renderGrid(profile);
        }

        function openModal(id) {
            const item = mockData.find(i => i.id === id);
            if (!item) return;

            const typeInfo = getTypeInfo(item.type);
            const modal = document.getElementById('file-modal');
            const content = document.getElementById('modal-content');

            // Generate content based on type
            let visualArea = '';
            if (item.isCode) {
                visualArea = `
                    <div class="w-full bg-[#1e1e1e] text-[#d4d4d4] font-mono text-sm p-6 overflow-y-auto" style="height: 300px;">
                        <div class="mb-4 text-gray-500">/* Pré-visualização do conteúdo de ${item.title} */</div>
                        <div class="text-blue-400">import</div> pandas <div class="text-blue-400">as</div> pd<br><br>
                        <div class="text-green-500"># Carregando o dataset</div><br>
                        df = pd.read_${item.type}('<span class="text-orange-300">dataset.${item.type}</span>')<br><br>
                        <div class="text-green-500"># Visualizando as primeiras linhas</div><br>
                        <span class="text-yellow-200">print</span>(df.head())<br><br>
                        >    id | nome       | valor | status<br>
                        >    1  | Item Alpha | 100.5 | Ativo<br>
                        >    2  | Item Beta  | 45.0  | Inativo<br>
                        ...
                    </div>
                `;
            } else if (item.image) {
                visualArea = `
                    <div class="w-full bg-gray-100 relative group flex items-center justify-center overflow-hidden" style="height: 300px;">
                        <img src="${item.image}" class="w-full h-full object-cover">
                        ${item.profile === 'video' ? '<div class="absolute inset-0 flex items-center justify-center bg-black/20"><button class="w-16 h-16 bg-white/90 rounded-full flex items-center justify-center text-gray-900 shadow-lg hover:scale-110 transition-transform"><i class="ph-fill ph-play text-2xl ml-1"></i></button></div>' : ''}
                    </div>
                `;
            }

            content.innerHTML = `
                <!-- Media/Preview Area -->
                ${visualArea}

                <!-- Content Area -->
                <div class="p-6 sm:p-8 flex-1 overflow-y-auto bg-white">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <div class="flex items-center gap-2 mb-2">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold ${typeInfo.bg} ${typeInfo.color}">
                                    <i class="ph ${typeInfo.icon} text-sm"></i>
                                    Formato .${item.type.toUpperCase()}
                                </span>
                                <span class="text-xs text-gray-500 bg-gray-100 px-2.5 py-1 rounded-md font-medium">CC0 Domínio Público</span>
                            </div>
                            <h2 class="text-2xl font-bold text-gray-900 mb-2">${item.title}</h2>
                            <p class="text-gray-600 text-sm leading-relaxed">${item.desc}</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-8 py-4 border-y border-gray-100">
                        <div>
                            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Tamanho</p>
                            <p class="text-sm font-medium text-gray-900 flex items-center gap-1"><i class="ph ph-hard-drives text-gray-400"></i> ${item.size}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Downloads</p>
                            <p class="text-sm font-medium text-gray-900 flex items-center gap-1"><i class="ph ph-download-simple text-gray-400"></i> ${item.downloads}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Data</p>
                            <p class="text-sm font-medium text-gray-900 flex items-center gap-1"><i class="ph ph-calendar-blank text-gray-400"></i> ${item.date}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Autor</p>
                            <p class="text-sm font-medium text-gray-900 flex items-center gap-1"><i class="ph ph-user text-gray-400"></i> ${item.author}</p>
                        </div>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="bg-gray-50 px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-gray-200">
                    <button class="text-gray-500 hover:text-gray-700 text-sm font-medium flex items-center gap-2 transition-colors">
                        <i class="ph ph-flag text-lg"></i> Reportar problema
                    </button>
                    <div class="flex gap-3 w-full sm:w-auto">
                        <button class="flex-1 sm:flex-none px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-colors shadow-sm flex items-center justify-center gap-2">
                            <i class="ph ph-bookmark-simple text-lg"></i> Salvar
                        </button>
                        <button onclick="downloadAlert()" class="flex-1 sm:flex-none px-6 py-2 bg-brand-600 text-white rounded-lg text-sm font-medium hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-colors shadow-sm flex items-center justify-center gap-2">
                            <i class="ph ph-download-simple text-lg"></i> Baixar Arquivo
                        </button>
                    </div>
                </div>
            `;

            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden'; // Prevent background scrolling
        }

        function closeModal() {
            const modal = document.getElementById('file-modal');
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto'; // Restore background scrolling
        }

        function downloadAlert() {
            // Custom modern "alert" using DOM instead of browser alert()
            const btn = event.currentTarget;
            const originalHTML = btn.innerHTML;
            const originalClasses = btn.className;
            
            btn.className = "flex-1 sm:flex-none px-6 py-2 bg-green-600 text-white rounded-lg text-sm font-medium focus:outline-none transition-colors shadow-sm flex items-center justify-center gap-2";
            btn.innerHTML = '<i class="ph ph-check-circle text-lg"></i> Iniciando...';
            
            setTimeout(() => {
                btn.className = originalClasses;
                btn.innerHTML = originalHTML;
                closeModal();
            }, 1500);
        }

        // Initialize on load
        window.onload = () => {
            setProfile('all');
            
            // Close modal on Escape key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeModal();
            });
        };
    </script>
</body>
