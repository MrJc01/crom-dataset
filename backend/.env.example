PORT=8080
ADMIN_API_KEY=troque-por-uma-chave-secreta-forte

# ── Provedores de Storage (o CROM é uma "casca" — dados vão para provedores externos) ──

# HuggingFace (Gratuito - https://huggingface.co/settings/tokens)
HF_TOKEN=hf_seu_token_hugging_face_aqui
HF_DEFAULT_REPO=seu-usuario/seu-dataset-repo

# Internet Archive (Gratuito - https://archive.org/account/s3.php)
IA_ACCESS_KEY=
IA_SECRET_KEY=
IA_ITEM_ID=crom-dataset-uploads

# Catbox.moe (Gratuito - sem conta necessária, upload anônimo)
# Nenhuma configuração necessária
